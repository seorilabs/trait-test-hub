{
  "name": "@seorilabs/trait-test-ait",
  "private": true,
  "scripts": {
    "bundle:core": "esbuild ../../packages/product-core/src/index.js --bundle --format=esm --platform=neutral --outfile=src/vendor/product-core.js && cp ../../packages/product-core/src/index.d.ts src/vendor/product-core.d.ts",
    "dev": "pnpm bundle:core && granite dev",
    "build": "pnpm bundle:core && ait build",
    "test": "pnpm bundle:core && jest --passWithNoTests",
    "typecheck": "pnpm bundle:core && tsc --noEmit",
    "lint": "eslint .",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "deploy": "ait deploy"
  },
  "dependencies": {
    "@apps-in-toss/framework": "^2.10.7",
    "@granite-js/native": "1.0.33",
    "@granite-js/react-native": "1.0.33",
    "@toss/tds-react-native": "^2.0.3",
    "brick-module": "0.5.1",
    "react": "19.2.3",
    "react-native": "0.84.0",
    "react-native-safe-area-context": "5.6.2"
  },
  "devDependencies": {
    "@babel/core": "7.28.5",
    "@babel/runtime": "7.28.4",
    "@eslint/js": "^9.17.0",
    "@granite-js/plugin-hermes": "1.0.33",
    "@granite-js/plugin-router": "1.0.33",
    "@testing-library/react-native": "13.3.3",
    "@types/babel__core": "^7.20.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/react": "19.2.0",
    "@types/react-test-renderer": "19.1.0",
    "babel-preset-granite": "1.0.33",
    "esbuild": "0.25.8",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "jest": "^29.7.0",
    "prettier": "3.4.2",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0"
  },
