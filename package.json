{
  "name": "trait-test-hub",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "description": "성향 테스트 허브 멀티마켓 앱 repo",
  "scripts": {
    "dev:preview": "node scripts/serve-preview.mjs",
    "generate:test-packs": "node scripts/generate-test-packs.mjs",
    "compile:test-packs": "node scripts/compile-test-packs.mjs",
    "sync:test-packs": "node scripts/compile-test-packs.mjs --output=public/test-packs",
    "validate:test-packs": "node scripts/compile-test-packs.mjs --output=tmp/test-packs-check && node scripts/validate-test-packs.mjs --assetRoot=tmp/test-packs-check",
    "validate:test-packs:public": "node scripts/validate-test-packs.mjs",
    "validate:test-packs:source": "pnpm validate:test-packs",
    "quality:test-packs": "node scripts/compile-test-packs.mjs --output=tmp/test-packs-check && node scripts/audit-test-pack-quality.mjs --assetRoot=tmp/test-packs-check",
    "check:content": "node scripts/compile-test-packs.mjs --output=tmp/test-packs-check && node scripts/validate-test-packs.mjs --assetRoot=tmp/test-packs-check && node scripts/audit-test-pack-quality.mjs --assetRoot=tmp/test-packs-check",
    "gen:result-images": "python3 scripts/gen-result-images.py",
    "list:test-topics": "node scripts/list-test-topics.mjs",
    "publish:test-pack-draft": "node scripts/publish-test-pack-draft.mjs",
    "build:pages": "node scripts/build-pages.mjs",
    "check": "pnpm check:core && pnpm check:content && pnpm check:preview && pnpm check:release",
    "check:core": "pnpm --dir packages/product-core check",
    "check:preview": "node scripts/check-preview.mjs",
    "check:mobile": "pnpm --dir apps/mobile check",
    "check:ait": "pnpm --dir apps/ait check",
    "check:release": "node scripts/check-release-blockers.mjs",
    "check:release:strict": "node scripts/check-release-blockers.mjs --strict",
    "build:android": "pnpm --dir apps/mobile build:android",
    "build:ios": "pnpm --dir apps/mobile build:ios",
    "build:ait": "pnpm --dir apps/ait build"
  }
}
